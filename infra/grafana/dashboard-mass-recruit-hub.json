{
  "dashboard": {
    "title": "MassRecruitHub Monitoring",
    "tags": ["massrecruit", "ai-agent"],
    "timezone": "browser",
    "panels": [
      {
        "title": "Candidates processed (total)",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(mrh_candidates_total)",
            "legendFormat": "total"
          }
        ]
      },
      {
        "title": "WER (Word Error Rate)",
        "type": "gauge",
        "targets": [
          {
            "expr": "mrh_wer",
            "legendFormat": "WER"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "orange", "value": 5 },
                { "color": "red", "value": 8 }
              ]
            }
          }
        }
      },
      {
        "title": "Latency P95 (voice)",
        "type": "heatmap",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(mrh_pipeline_duration_seconds_bucket{agent_stage=\"interviewer_conduct\"}[5m])) by (le))",
            "legendFormat": "P95"
          }
        ]
      },
      {
        "title": "Fairness Disparate Impact",
        "type": "stat",
        "targets": [
          {
            "expr": "mrh_fairness_disparate_impact",
            "legendFormat": "DI"
          }
        ]
      },
      {
        "title": "Human review required (rate)",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(mrh_human_review_required_total[5m])",
            "legendFormat": "{{stage}}"
          }
        ]
      },
      {
        "title": "Semantic cache hit ratio",
        "type": "gauge",
        "targets": [
          {
            "expr": "sum(mrh_semantic_cache_hits_total) / (sum(mrh_semantic_cache_hits_total) + sum(mrh_semantic_cache_misses_total))",
            "legendFormat": "hit ratio"
          }
        ]
      }
    ]
  },
  "overwrite": true
}
